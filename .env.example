# ========================================
# Ting Learning Platform 环境配置文件
# ========================================

# ========================
# 数据库配置
# ========================
DATABASE_URL=postgresql://ting_user:ting_password@localhost:5432/ting_db
POSTGRES_DB=ting_db
POSTGRES_USER=ting_user
POSTGRES_PASSWORD=ting_password

# ========================
# Redis配置
# ========================
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ========================
# JWT认证配置
# ========================
SECRET_KEY=your-very-secure-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24小时
REFRESH_TOKEN_EXPIRE_DAYS=30

# ========================
# 微信配置
# ========================
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret
WECHAT_TOKEN=your_wechat_token
WECHAT_ENCODING_AES_KEY=your_encoding_aes_key

# 微信支付配置
WECHAT_PAY_APPID=your_wechat_pay_appid
WECHAT_PAY_MCH_ID=your_wechat_pay_mch_id
WECHAT_PAY_API_KEY=your_wechat_pay_api_key
WECHAT_PAY_NOTIFY_URL=http://yourdomain.com/api/v1/wechat/pay/notify

# ========================
# 短信服务配置 (阿里云)
# ========================
ALIBABA_ACCESS_KEY_ID=your_alibaba_access_key_id
ALIBABA_ACCESS_KEY_SECRET=your_alibaba_access_key_secret
SMS_SIGN_NAME=您的短信签名
SMS_TEMPLATE_CODE=SMS_XXXXXXXXX

# ========================
# 邮件服务配置
# ========================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com

# ========================
# 文件存储配置 (阿里云OSS)
# ========================
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET_NAME=your_bucket_name
OSS_CDN_DOMAIN=https://your-cdn-domain.com

# ========================
# 消息推送配置 (极光推送)
# ========================
JPUSH_APP_KEY=your_jpush_app_key
JPUSH_MASTER_SECRET=your_jpush_master_secret

# ========================
# 搜索服务配置 (Elasticsearch)
# ========================
ELASTICSEARCH_HOST=elasticsearch:9200

# ========================
# 缓存配置
# ========================
CACHE_DEFAULT_TTL=3600
CACHE_LONG_TTL=86400

# ========================
# 业务配置
# ========================
DEBUG=false
ENVIRONMENT=production
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE=52428800  # 50MB
ALLOWED_FILE_TYPES=mp4,mp3,avi,mov,wav,m4a
POINT_EXPIRATION_DAYS=365  # 积分有效期(天)

# ========================
# API配置
# ========================
API_V1_STR=/api/v1
PROJECT_NAME=Ting Learning Platform
VERSION=1.0.0
DESCRIPTION=视频音频学习赚积分平台

# ========================
# CORS配置
# ========================
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8080", "https://yourdomain.com"]

# ========================
# 积分配置
# ========================
POINTS_PER_VIDEO_MINUTE=5    # 观看视频每分钟获得积分
POINTS_PER_AUDIO_MINUTE=3    # 收听音频每分钟获得积分
POINTS_PER_CORRECT_ANSWER=20 # 答题正确获得积分
POINTS_PER_DAILY_CHECKIN=10  # 每日签到获得积分
POINTS_PER_INVITATION=100    # 邀请好友获得积分

# ========================
# 渠道配置
# ========================
CHANNEL_COMMISSION_RATE=10.0  # 渠道佣金比例(%)
MAX_CHANNEL_LEVELS=5          # 最大渠道层级
RETRY_LIMIT_PER_QUESTION=3    # 每题最大重试次数

# ========================
# 商城配置
# ========================
MAX_EXCHANGE_PER_USER=1       # 单用户最大兑换次数
EXPIRATION_DAYS_VIRTUAL=30    # 虚拟商品有效期(天)
EXPIRATION_DAYS_PHYSICAL=365  # 实物商品有效期(天)

# ========================
# 防作弊配置
# ========================
MIN_WATCH_DURATION_SECONDS=10  # 最小观看时长(秒)
MAX_SPEED_MULTIPLIER=2.0       # 最大播放倍速
ANSWER_TIME_THRESHOLD=5        # 答题时间阈值(秒)
MAX_DAILY_QUIZ_ATTEMPTS=10     # 每日最大答题次数
